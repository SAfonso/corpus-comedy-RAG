# ============================================================================
# Comedy Corpus Pipeline — plantilla de variables de entorno
# ----------------------------------------------------------------------------
# Copia este fichero a `.env` y rellena los valores. NUNCA subas `.env` a git
# (ya está en .gitignore). Ningún valor real debe vivir en el repositorio.
# ============================================================================

# ---------------------------------------------------------------------------
# Transcripción de vídeos — WhisperX (paso previo en Colab, fuera del pipeline)
# ---------------------------------------------------------------------------
# Token de Hugging Face con los términos de los modelos gated de pyannote
# (segmentation + speaker-diarization) aceptados.
HF_TOKEN=

# ---------------------------------------------------------------------------
# Flujo A — Teoría (Google Drive + traducción)
# ---------------------------------------------------------------------------
# Ruta al JSON de credenciales de la cuenta de servicio de Google (Drive API).
GOOGLE_APPLICATION_CREDENTIALS=./secrets/google-service-account.json
# ID de la carpeta de Drive que monitoriza el DriveMonitor.
DRIVE_FOLDER_ID=

# Traducción de teoría a español (elige UNA vía; deep-translator soporta ambas).
# DeepL free tier:
DEEPL_API_KEY=
# ...o LibreTranslate self-host (si se usa en lugar de DeepL):
LIBRETRANSLATE_URL=

# OCR — ruta al binario de Tesseract si no está en el PATH (opcional).
# TESSERACT_CMD=/usr/bin/tesseract

# ---------------------------------------------------------------------------
# Flujo C — Histórico (Google Drive real, ver src/jokes/historico/SPEC.md P19)
# ---------------------------------------------------------------------------
# Reutiliza GOOGLE_APPLICATION_CREDENTIALS de arriba (misma cuenta de servicio,
# scope drive.readonly; en CI se inyecta por secreto, nunca OAuth interactivo).
# ID de la carpeta de Drive del HISTÓRICO — distinta de la de teoría
# (DRIVE_FOLDER_ID). drive_source.py descarga sus .docx nuevos/modificados a un
# staging local antes de marcar_remates.
DRIVE_FOLDER_ID_HISTORICO=

# ---------------------------------------------------------------------------
# Flujos B/C — Chistes (Supabase)
# ---------------------------------------------------------------------------
SUPABASE_URL=
# Clave service_role (backend). No usar la anon key para escritura.
SUPABASE_SERVICE_KEY=

# ---------------------------------------------------------------------------
# Flujo B — Telegram (chistes propios en tiempo real)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=

# ---------------------------------------------------------------------------
# LLM del Silver + embeddings (chistes)
# ---------------------------------------------------------------------------
# Proveedor LLM aún por decidir en la spec (§14): "LLM barato vía API".
# Rellena la clave del proveedor que se elija; deja las demás vacías.
LLM_API_KEY=
# Modelo a usar (ej.: un modelo barato del proveedor elegido).
LLM_MODEL=
# Clave para el modelo de embeddings (pgvector) si el proveedor difiere.
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=
